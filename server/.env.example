# Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Cloud Connection
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/codelang?retryWrites=true&w=majority

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your-jwt-secret-here-generate-a-secure-one
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here-generate-a-secure-one

# JWT Expiration
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server Port
PORT=3000

# Node Environment
NODE_ENV=development

# Gemini AI for Active Lingo Coach
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
